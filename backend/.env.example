# Application
NODE_ENV=development
PORT=3001
APP_NAME=shentong-ai-backend

# Database (MySQL 8.0)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=ai_agent

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Throttler
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Swagger
SWAGGER_PATH=api/docs

# Admin JWT
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-me
ADMIN_JWT_EXPIRES_IN=8h
