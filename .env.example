# =============================================================================
# 深瞳AI 全栈部署环境变量
# 使用方法:cp .env.example .env && 修改密码与密钥
# =============================================================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=shentong_root_2026
MYSQL_DATABASE=ai_agent
MYSQL_USER=shentong
MYSQL_PASSWORD=shentong_pwd_2026

# Redis 配置
REDIS_PASSWORD=shentong_redis_2026

# JWT 密钥(生产环境务必修改,至少 32 字符)
JWT_SECRET=change-me-in-production-at-least-32-chars-please
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS 允许的源(多个用逗号分隔,* 表示允许所有)
CORS_ORIGINS=*

# 限流配置
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Swagger 文档路径
SWAGGER_PATH=api/docs
