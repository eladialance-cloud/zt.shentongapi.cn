{
  "name": "shentong-ai-desktop",
  "version": "0.1.0",
  "description": "深瞳AI 桌面客户端 - 基于 Electron 的智能中台桌面软件",
  "author": "Shentong",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "lint": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "jest",
    "test:e2e": "jest --config jest.config.ts --testPathPattern=tests/e2e",
    "prebuild:win": "tsx scripts/fetch-runtime.ts --win",
    "prebuild:mac": "tsx scripts/fetch-runtime.ts --mac",
    "fetch-runtime": "tsx scripts/fetch-runtime.ts",
    "pack:win": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -Target win",
    "pack:mac": "bash scripts/build-installer.sh --target mac",
    "pack:all": "bash scripts/build-installer.sh --target all",
    "gen-latest-yml": "tsx scripts/generate-latest-yml.ts",
    "verify-installer": "tsx scripts/verify-installer.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@journeyapps/sqlcipher": "^5.3.1",
    "antd": "^5.21.6",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "//_jest_deps": "未实际安装的 Jest 测试依赖，需要时执行: npm install -D @types/jest@^29.5.0 jest@^29.7.0 jest-environment-jsdom@^29.7.0 ts-jest@^29.1.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^31.7.5",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.0",
    "vite": "^5.4.10"
  }
}
